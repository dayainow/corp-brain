# 로컬 빠른 모드 — Mac PoC·일상 개발용
# Cross-encoder OFF, 가벼운 LLM (기본 llama3 / 선택 llama3.2:3b)

AUTH_URL=http://localhost:3000
VAULT_PATH=./vault
EMBEDDING_MODEL=Xenova/multilingual-e5-small

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
OLLAMA_API_KEY=ollama
# 더 가볍게: OLLAMA_MODEL=llama3.2:3b  (ollama pull llama3.2:3b)

RAG_TOP_K=5
CROSS_ENCODER_MODEL=
CROSS_ENCODER_TOP_N=10
CROSS_ENCODER_WEIGHT=2

VECTOR_STORE=json
