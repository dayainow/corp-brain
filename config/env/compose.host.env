# Compose ьўИВіцьіИ CLIВџЕ Рђћ postgres/redisвіћ localhost, ВЋ▒ВЮђ Docker
# Usage: set -a && source config/env/compose.host.env && set +a

AUTH_URL=http://localhost:3000
