# ── CorpBrain 환경 변수 ──────────────────────────────────────
# 이 파일을 .env.local 로 복사한 뒤 값을 채워주세요.
# cp .env.example .env.local

# NextAuth (필수)
AUTH_SECRET=your-random-secret-at-least-32-chars-long
AUTH_URL=http://localhost:3000

# 문서 Vault 경로 (인덱싱·업로드 대상)
VAULT_PATH=./sample-docs

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# RAG 설정
RAG_TOP_K=5
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# 벡터 저장소 (json | pgvector — pgvector는 Phase 2B)
VECTOR_STORE=json
# DATABASE_URL=postgresql://corpbrain:corpbrain@localhost:5432/corpbrain

# 감사 로그
AUDIT_LOG_PATH=./data/audit.log
