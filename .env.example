# 필수 — NextAuth JWT 서명 (32자 이상)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# 문서 Vault 경로
VAULT_PATH=./vault
EMBEDDING_MODEL=Xenova/multilingual-e5-small

# Ollama (로컬 LLM)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
OLLAMA_API_KEY=ollama

# RAG
RAG_TOP_K=5
# 선택: Cross-encoder 리랭킹 (미설정 시 비활성화)
# 예시: Xenova/ms-marco-MiniLM-L-6-v2 (ONNX, transformers.js 호환)
CROSS_ENCODER_MODEL=
CROSS_ENCODER_TOP_N=10
CROSS_ENCODER_WEIGHT=2

# 벡터 스토어: json | pgvector
VECTOR_STORE=json
DATABASE_URL=postgresql://corpbrain:corpbrain@localhost:5432/corpbrain

# Redis (Rate limit, 다중 인스턴스)
REDIS_URL=redis://localhost:6379

# Google Workspace SSO (선택)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack Slash Command (선택)
SLACK_SIGNING_SECRET=
# Slack User ID → novapay 이메일 매핑 (JSON)
# SLACK_USER_MAP={"U01234":"lee.minho@novapay.kr"}

# health degraded 알림 (A10, health:watch)
HEALTH_ALERT_WEBHOOK_URL=
AUDIT_LOG_PATH=./data/audit.log
AUDIT_WEBHOOK_URL=
