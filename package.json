{
  "name": "corp-brain",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fast": "bash scripts/use-env-preset.sh fast && next dev",
    "dev:quality": "bash scripts/use-env-preset.sh quality && next dev",
    "env:fast": "bash scripts/use-env-preset.sh fast",
    "env:quality": "bash scripts/use-env-preset.sh quality",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:init": "tsx scripts/init-db.ts",
    "db:migrate": "tsx scripts/migrate-to-pgvector.ts",
    "eval:search": "tsx scripts/eval-search.ts",
    "eval:embedding-ab": "tsx scripts/eval-embedding-ab.ts",
    "index:vault": "tsx scripts/index-vault.ts",
    "harness:quality": "tsx scripts/run-quality-harness.ts",
    "quality:gate": "npm run index:vault && npm run harness:quality",
    "quality:full": "npm run quality:gate && npm run quality:loop",
    "deploy:compose": "bash scripts/deploy-compose.sh",
    "smoke:compose": "bash scripts/pilot-compose-smoke.sh",
    "pilot:preflight": "bash scripts/pilot-preflight.sh",
    "pilot:ready": "bash scripts/pilot-preflight.sh --ready",
    "health:watch": "bash scripts/health-watch.sh",
    "report:feedback": "tsx scripts/report-feedback.ts",
    "report:pilot-weekly": "tsx scripts/report-pilot-weekly.ts",
    "quality:loop": "npm run lint && npm test && npm run harness:quality && npm run build && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:rag": "playwright test e2e/rag-ollama.spec.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.79",
    "@ai-sdk/react": "^3.0.219",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.217",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "ollama-ai-provider": "^1.2.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "redis": "^4.7.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/marked": "^5.0.2",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
